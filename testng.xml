<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Test Cases Suite" parallel="tests" thread-count="2">

    <test name="Method Mode">
        <parameter name="browser" value="chrome"/>
        <parameter name="executionMode" value="method"/>
        <classes>
            <class name="com.automation.Testcase1"/>
        </classes>
    </test>

    <test name="Class Mode">
        <parameter name="browser" value="chrome"/>
        <parameter name="executionMode" value="class"/>
        <classes>
            <class name="com.automation.Testcase1"/>
        </classes>
    </test>

    <listeners>
        <listener class-name="com.automation.Listener"/>
    </listeners>

</suite>